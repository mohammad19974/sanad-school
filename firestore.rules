// قواعد أمان Firestore لتطبيق سند
// كل قاعدة موثّقة لتسهيل فهم الطلاب

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ───── ملفات الطلاب ─────
    // كل طالب يقرأ ويعدّل ملفه فقط
    match /students/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ───── الملاجئ ─────
    // قراءة عامة (متاحة للطلاب المسجّلين)، التعديل من الإدارة عبر Console فقط
    match /shelters/{shelterId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ───── طلبات النجدة ─────
    // الطالب يقرأ طلبه الخاصّ فقط
    // الإنشاء يتم عبر Cloud Function (admin SDK يتجاوز القواعد)
    match /sosRequests/{requestId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.studentId;
      allow create: if false;  // فقط عبر Cloud Function
      allow update, delete: if false;
    }

    // ───── أرقام الطوارئ العامّة ─────
    match /emergencyContacts/{country} {
      allow read: if true;
      allow write: if false;
    }
  }
}
