// قواعد أمان Firestore — نظام دورَين (طالب + منسّق)

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ───── دالّات مساعدة ─────
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/students/$(request.auth.uid))
        && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'staff';
    }

    // ───── ملفات المستخدمين (طلاب ومنسّقين) ─────
    match /students/{uid} {
      // المستخدم يقرأ ملفه دائماً
      // المنسّق يقرأ كل الملفات
      allow read:   if isSelf(uid) || isStaff();
      // المستخدم يكتب ملفه فقط
      allow write:  if isSelf(uid);
    }

    // ───── الملاجئ ─────
    match /shelters/{shelterId} {
      allow read:  if isSignedIn();
      allow write: if false;  // فقط من Console
    }

    // ───── طلبات النجدة ─────
    match /sosRequests/{requestId} {
      // الطالب يرى طلباته، المنسّق يرى الكلّ
      allow read:   if isSignedIn() && (
                      resource.data.studentId == request.auth.uid || isStaff()
                    );
      // الطالب ينشئ طلبه مباشرة (وضع مجاني بدون Cloud Function)
      // الشروط: studentId = uid، status pending، snapshot.uid = uid
      allow create: if isSignedIn()
                    && request.resource.data.studentId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.studentSnapshot.uid == request.auth.uid;
      // التعديل: الطالب (يلغي طلبه + يضبط lastSeenByStudent)، المنسّق يغيّر أيّ شيء
      allow update: if isSignedIn() && (
                      // الطالب يحدّث طلبه (إلغاء أو ضبط lastSeenByStudent)
                      resource.data.studentId == request.auth.uid
                      || isStaff()
                    );
      allow delete: if false;

      // ───── رسائل chat لكل طلب ─────
      match /messages/{messageId} {
        allow read:   if isSignedIn() && (
                        get(/databases/$(database)/documents/sosRequests/$(requestId)).data.studentId == request.auth.uid
                        || isStaff()
                      );
        // المرسل يجب أن يكون مرتبطاً بالطلب
        allow create: if isSignedIn()
                      && request.resource.data.senderUid == request.auth.uid
                      && (
                        get(/databases/$(database)/documents/sosRequests/$(requestId)).data.studentId == request.auth.uid
                        || isStaff()
                      );
        allow update, delete: if false;  // الرسائل غير قابلة للتعديل
      }

      // ───── حالة "يكتب الآن..." ─────
      // المسار: typing/{uid} — المالك uid فقط يكتب/يحذف، الطرفان يقرآن
      match /typing/{uid} {
        allow read: if isSignedIn() && (
                      get(/databases/$(database)/documents/sosRequests/$(requestId)).data.studentId == request.auth.uid
                      || isStaff()
                    );
        allow write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ───── أرقام الطوارئ العامّة ─────
    match /emergencyContacts/{country} {
      allow read:  if true;
      allow write: if false;
    }
  }
}
